{
  "projectType": "sdk-library",
  "projectName": "Laravel Livewire Tables",
  "projectDescription": "Full-featured reactive data tables for Laravel with sorting, filtering, pagination, bulk actions, and CSV export",
  "theme": "palm",
  "primaryColor": "#7b86aa",
  "lightColor": "#22273a",
  "darkColor": "#cacfdf",
  "navigation": {
