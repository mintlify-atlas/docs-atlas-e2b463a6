            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "Reactive data tables with Livewire 3 & 4",
    "Search, sort, filter, and pagination",
    "Bulk actions with select-all support",
    "CSV export functionality",
    "Multiple column types (Text, Boolean, Date, Image, Action, Blade)",
    "Multiple filter types with dependent filter support",
    "Tailwind CSS, Bootstrap 5, and Bootstrap 4 themes",
    "Dark mode support",
    "Lifecycle hooks and event system",
    "Toolbar customization slots",
    "Join support for related tables",
    "State persistence across sessions"
  ],
  "publicApiSurface": [
    "DataTableComponent",
    "TextColumn",
    "BooleanColumn",
    "DateColumn",
    "ImageColumn",
    "ActionColumn",
    "BladeColumn",
    "TextFilter",
    "SelectFilter",
    "BooleanFilter",
    "NumberFilter",
    "NumberRangeFilter",
    "DateFilter",
    "DateRangeFilter",
    "MultiDateFilter",
    "configure()",
    "query()",
    "columns()",
    "filters()",
    "bulkActions()",
    "getSelectedIds()",
    "setDefaultPerPage()",
    "setSearchDebounce()",
    "setDefaultSortDirection()",
    "setEmptyMessage()"
  ]
}
